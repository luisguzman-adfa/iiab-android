<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/dash_bg_main"
    android:padding="16dp"
    android:baselineAligned="false"
    android:weightSum="2">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingEnd="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kiwix Language"
            android:textColor="@color/dash_text_secondary"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>

        <Spinner
            android:id="@+id/spinner_kiwix_lang"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/dash_module_bg"
            android:popupBackground="@color/dash_bg_card"
            android:layout_marginBottom="16dp"/>

        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <Button
            android:id="@+id/btn_wipe_cache"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Wipe ZIM Cache"
            android:textColor="#FFFFFF"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#0000FF" />

        <Button
            android:id="@+id/btn_select_variant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"
            android:textAllCaps="false"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#008000" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/rounded_button"
        android:backgroundTint="@color/dash_module_bg"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Available ZIM Variants"
            android:textColor="@color/dash_text_primary"
            android:textStyle="bold"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="180dp">
            <RadioGroup
                android:id="@+id/rg_kiwix_variants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>