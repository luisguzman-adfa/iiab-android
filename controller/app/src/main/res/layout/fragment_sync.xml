<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="?android:attr/windowBackground">

    <RadioGroup
        android:id="@+id/rg_sync_mode"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="@drawable/rounded_button"
        android:backgroundTint="#333333"
        android:layout_marginBottom="24dp">

        <RadioButton
            android:id="@+id/rb_mode_share"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/radio_selector_bg"
            android:button="@null"
            android:gravity="center"
            android:text="@string/sync_mode_share"
            android:textColor="@color/dash_text_primary"
            android:textStyle="bold"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rb_mode_receive"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@drawable/radio_selector_bg"
            android:button="@null"
            android:gravity="center"
            android:text="@string/sync_mode_receive"
            android:textColor="@color/dash_text_secondary"
            android:textStyle="bold" />
    </RadioGroup>

    <LinearLayout
        android:id="@+id/container_share"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        tools:visibility="visible">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sync_share_desc"
            android:textColor="@color/dash_text_secondary"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <FrameLayout
            android:id="@+id/qr_card_container"
            android:layout_width="220dp"
            android:layout_height="220dp"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF"
            android:padding="8dp"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:id="@+id/img_qr_code"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                tools:src="@android:drawable/ic_dialog_info"
                android:contentDescription="@string/sync_btn_scan_qr" />

            <ImageButton
                android:id="@+id/btn_flip_qr"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="4dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_sync"
                android:tint="#000000"
                android:visibility="gone"
                tools:visibility="visible" />
        </FrameLayout>

        <TextView
            android:id="@+id/txt_share_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sync_share_status_off"
            android:textColor="#FF9800"
            android:textSize="14sp"
            android:textStyle="italic"
            android:textAlignment="center"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btn_start_server"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginHorizontal="12dp"
            android:text="@string/sync_btn_start_server"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#008000"
            android:textAllCaps="false" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/container_receive"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:visibility="gone"
        tools:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/sync_receive_desc"
            android:textColor="@color/dash_text_secondary"
            android:textSize="14sp"
            android:textAlignment="center"
            android:layout_marginBottom="24dp" />

        <Button
            android:id="@+id/btn_scan_qr"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginHorizontal="12dp"
            android:text="@string/sync_btn_scan_qr"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_button"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="24dp"
            android:textAllCaps="false"
            app:icon="@android:drawable/ic_menu_camera"
            app:iconGravity="textStart" />

        <LinearLayout
            android:id="@+id/container_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/dash_module_bg"
            android:padding="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <TextView
                android:id="@+id/txt_transfer_filename"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/sync_transfer_filename"
                android:textColor="@color/dash_text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <ProgressBar
                android:id="@+id/progress_bar_transfer"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100"
                android:progress="0"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/txt_transfer_speed"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sync_transfer_speed_default"
                    android:textColor="@color/dash_text_secondary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/txt_transfer_eta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sync_transfer_eta_default"
                    android:textColor="@color/dash_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_cancel_transfer"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="16dp"
                android:text="@string/sync_btn_cancel_transfer"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#F44336"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textAllCaps="false" />

        </LinearLayout>
    </LinearLayout>

</LinearLayout>