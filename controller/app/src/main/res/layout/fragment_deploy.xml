<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/container_adb_leds"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/dash_module_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp"
            android:paddingBottom="10dp"
            android:layout_marginBottom="16dp"
            android:gravity="top"
            android:baselineAligned="false"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <View
                    android:id="@+id/led_install_internet"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_internet"
                    android:textColor="@color/dash_text_inverted"
                    android:fontFamily="@font/orbitron"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/led_install_dev_mode"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_dev_options"
                    android:textColor="@color/dash_text_inverted"
                    android:fontFamily="@font/orbitron"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_led_dcpr"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/led_install_dcpr"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txt_install_dcpr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_child_process"
                    android:textColor="@color/dash_text_secondary"
                    android:fontFamily="@font/orbitron"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_led_ppk"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/led_install_ppk"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />

                <TextView
                    android:id="@+id/txt_install_ppk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_ppk"
                    android:textColor="@color/dash_text_secondary"
                    android:fontFamily="@font/orbitron"
                    android:textSize="9sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/banner_server_warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/surface_active_warning"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/install_warning_server_icon"
                android:textSize="16sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/install_warning_server_running"
                android:textColor="@color/status_warning"
                android:textSize="13sp"
                android:gravity="center"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/section_adv_monitoring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/txt_adv_monitoring_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/install_adv_monitoring_title"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?android:attr/textColorPrimary"
                android:paddingVertical="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_divider"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/container_adv_monitoring"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_desc_monitoring"
                    android:textColor="@color/dash_text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btn_adb_action"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:text="@string/adb_btn_connect"
                        android:textColor="@color/text_on_accent"
                        android:textStyle="bold"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="@color/status_info"
                        android:textAllCaps="false"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="@color/dash_module_bg"
                        android:paddingHorizontal="24dp">

                        <View
                            android:id="@+id/led_adb_status"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/led_off"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/txt_adb_led_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/adb_status_offline"
                            android:textColor="@color/dash_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="@color/dash_module_bg"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/adb_graph_title"
                        android:textColor="@color/dash_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="8dp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/cpu_chart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/install_header_fast"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_divider"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/install_desc_fast"
            android:textColor="@color/dash_text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/dash_module_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <org.iiab.controller.MultiResourceGaugeView
                        android:id="@+id/storage_projection_gauge"
                        android:layout_width="130dp"
                        android:layout_height="130dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp">

                    <Button
                        android:id="@+id/btn_tier_basic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/install_tier_basic"
                        android:textColor="@color/text_on_accent"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="@color/btn_neutral"
                        android:textAllCaps="false"/>

                    <Button
                        android:id="@+id/btn_tier_standard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/install_tier_standard"
                        android:textColor="@color/text_on_accent"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="@color/btn_neutral"
                        android:layout_marginTop="8dp"
                        android:textAllCaps="false"/>

                    <Button
                        android:id="@+id/btn_tier_full"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="48dp"
                        android:text="@string/install_tier_full"
                        android:textColor="@color/text_on_accent"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="@color/btn_neutral"
                        android:layout_marginTop="8dp"
                        android:textAllCaps="false"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp"
                android:weightSum="4">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:gravity="center">
                    <CheckBox
                        android:id="@+id/chk_companion_data"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/install_chk_companion"
                        android:textSize="12sp"
                        android:textColor="@color/dash_text_secondary"
                        android:buttonTint="@color/status_success" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center">
                    <ImageButton
                        android:id="@+id/btn_kiwix_settings"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/outline_dashboard_2_gear_24"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        app:tint="@color/text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/surface_section"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:weightSum="2">

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingEnd="12dp">
                        <View android:id="@+id/dot_iiab" android:layout_width="10dp" android:layout_height="10dp" android:background="@color/chart_os" android:layout_centerVertical="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/install_legend_iiab" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/dash_text_secondary" android:layout_toEndOf="@id/dot_iiab" android:layout_marginStart="6dp" android:layout_centerVertical="true"/>
                        <TextView android:id="@+id/txt_legend_iiab" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0G" android:textSize="12sp" android:textColor="@color/dash_text_inverted" android:fontFamily="@font/orbitron" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp">
                        <View android:id="@+id/dot_maps" android:layout_width="10dp" android:layout_height="10dp" android:background="@color/chart_maps" android:layout_centerVertical="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/install_legend_maps" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/dash_text_secondary" android:layout_toEndOf="@id/dot_maps" android:layout_marginStart="6dp" android:layout_centerVertical="true"/>
                        <TextView android:id="@+id/txt_legend_maps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0G" android:textSize="12sp" android:textColor="@color/dash_text_inverted" android:fontFamily="@font/orbitron" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="8dp"
                    android:baselineAligned="false"
                    android:weightSum="2">

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingEnd="12dp">
                        <View android:id="@+id/dot_kiwix" android:layout_width="10dp" android:layout_height="10dp" android:background="@color/chart_wiki" android:layout_centerVertical="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/install_legend_kiwix" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/dash_text_secondary" android:layout_toEndOf="@id/dot_kiwix" android:layout_marginStart="6dp" android:layout_centerVertical="true"/>
                        <TextView android:id="@+id/txt_legend_kiwix" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0G" android:textSize="12sp" android:textColor="@color/dash_text_inverted" android:fontFamily="@font/orbitron" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
                    </RelativeLayout>

                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp">
                        <View android:id="@+id/dot_free" android:layout_width="10dp" android:layout_height="10dp" android:background="@color/chart_track" android:layout_centerVertical="true"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/install_legend_free" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/dash_text_secondary" android:layout_toEndOf="@id/dot_free" android:layout_marginStart="6dp" android:layout_centerVertical="true"/>
                        <TextView android:id="@+id/txt_legend_free" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="0.0G" android:textSize="12sp" android:textColor="@color/dash_text_inverted" android:fontFamily="@font/orbitron" android:layout_alignParentEnd="true" android:layout_centerVertical="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/txt_offline_estimate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/install_offline_estimated"
            android:textColor="@color/dash_text_secondary"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_fast_install"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="@string/install_btn_provision"
                android:textColor="@color/text_on_accent"
                android:textStyle="bold"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/status_success"
                android:layout_marginEnd="8dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_fast_delete"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="@string/install_btn_delete"
                android:textColor="@color/text_on_accent"
                android:textStyle="bold"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/status_danger"
                android:layout_marginStart="8dp"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/txt_module_mgmt_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/install_header_roles"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btn_refresh_modules"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/install_btn_refresh"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_divider"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/container_module_mgmt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/install_modules_disclaimer"
                android:textColor="@color/dash_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:id="@+id/install_roles_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"></LinearLayout>

            <LinearLayout
                android:id="@+id/install_discrepancy_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/surface_active_danger"
                android:padding="12dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_warning_discrepancy_icon"
                    android:textColor="@color/status_danger"
                    android:textSize="16sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txt_discrepancy_msg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/install_warning_discrepancy_msg"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_launch_install"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/install_btn_launch"
                android:textColor="@color/text_on_accent"
                android:textStyle="bold"
                android:background="@drawable/rounded_button"
                android:backgroundTint="@color/status_success"
                android:layout_marginBottom="32dp"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_maintenance_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/install_header_maintenance"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_divider"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/container_maintenance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/install_desc_maintenance"
                android:textColor="@color/dash_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/btn_advanced_backup"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/install_btn_backup"
                    android:textColor="@color/text_on_accent"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="@color/status_info"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_advanced_reset"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/install_btn_reset"
                    android:textColor="@color/text_on_warning"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="@color/status_pending"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/btn_advanced_restore"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/install_btn_restore"
                    android:textColor="@color/text_on_accent"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="@color/status_success"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_advanced_force_stop"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/install_btn_force_stop"
                    android:textColor="@color/text_on_accent"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="@color/status_danger"
                    android:textAllCaps="false" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_import_backup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:text="@string/install_btn_import_backup"
                android:textColor="?android:attr/textColorSecondary"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:background="?attr/selectableItemBackground"
                app:icon="@android:drawable/stat_sys_download"
                app:iconTint="@color/status_success"
                app:iconGravity="textStart" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/txt_select_backup_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/install_adv_select_backup"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/container_backup_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txt_backup_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/install_msg_fetching_backups"
                        android:textColor="@color/dash_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>
</ScrollView>